# ========================================
# VisionFeast - Environment Variables
# ========================================

# Environment
# development | production
ENVIRONMENT=development

# MongoDB Configuration
# Local: mongodb://localhost:27017/visionfeast_db
# Docker: mongodb://mongodb:27017/visionfeast_db
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/visionfeast_db?retryWrites=true&w=majority
# Railway MongoDB: ${{MongoDB.MONGO_URL}}
MONGODB_URI=mongodb://localhost:27017/visionfeast_db

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google OAuth
# Obtén estas credenciales en: https://console.cloud.google.com/
# Usa el Web Client ID para GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT Configuration
# Genera una clave secreta fuerte (puedes usar: openssl rand -hex 32)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend/CORS Configuration
# Local: http://localhost:8000
# Railway: https://visualfeast-production.up.railway.app
# Allow all: *
FRONTEND_URL=*

# ========================================
# Notas:
# - Copia este archivo como .env y configura tus valores reales
# - NUNCA commitees el archivo .env al repositorio
# - Para Railway, configura las variables en el dashboard
# - Consulta RAILWAY_DEPLOYMENT.md para deployment
# - Consulta backend/GOOGLE_AUTH_SETUP.md para OAuth
# ========================================
